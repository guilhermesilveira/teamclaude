{
  "proxy": {
    "port": 3456,
    "apiKey": "tc-change-me-to-a-secret"
  },
  "upstream": "https://api.anthropic.com",
  "switchThreshold": 0.98,
  "usageRefreshIntervalSeconds": 60,
  "modelFallback": {
    "sonnet7dThreshold": 0.9,
    "opusModel": "claude-opus-4-6"
  },
  "accounts": [
    {
      "name": "primary-max",
      "type": "oauth",
      "importFrom": "~/.claude/.credentials.json"
    },
    {
      "name": "secondary-max",
      "type": "oauth",
      "accessToken": "sk-ant-oat01-your-access-token",
      "refreshToken": "sk-ant-ort01-your-refresh-token"
    },
    {
      "name": "api-fallback",
      "type": "apikey",
      "apiKey": "sk-ant-api03-your-api-key"
    }
  ]
}
